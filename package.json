{
  "name": "sonicmaster",
  "version": "1.0.0",
  "description": "music player",
  "author": "Prefenzo Technologies <offcial@prefenzotechnologies.com>",
  "build": {
    "appId": "com.sonicmaster.player",
    "productName": "SonicMaster",
    "compression": "maximum",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "!dist-electron/**/*.map",
      "out/**/*",
      "package.json",
      "public/icon.png"
    ],
    "win": {
      "icon": "public/icon.png",
      "target": [
        "dir"
      ],
      "fileAssociations": [
        {
          "ext": [
            "mp3",
            "wav",
            "flac",
            "ogg",
            "m4a",
            "aac",
            "wma"
          ],
          "name": "Audio File",
          "description": "SonicMaster Audio File",
          "icon": "public/icon.png"
        },
        {
          "ext": [
            "lrc",
            "txt"
          ],
          "name": "Lyrics File",
          "description": "SonicMaster Lyrics File",
          "icon": "public/icon.png"
        }
      ]
    },
    "linux": {
      "artifactName": "SonicMaster-${version}.${ext}",
      "icon": "public/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "AudioVideo",
      "fileAssociations": [
        {
          "ext": "mp3",
          "name": "MP3 Audio File",
          "description": "SonicMaster MP3 Audio File",
          "icon": "public/icon.png"
        },
        {
          "ext": "wav",
          "name": "WAV Audio File",
          "description": "SonicMaster WAV Audio File",
          "icon": "public/icon.png"
        },
        {
          "ext": "flac",
          "name": "FLAC Audio File",
          "description": "SonicMaster FLAC Audio File",
          "icon": "public/icon.png"
        },
        {
          "ext": "ogg",
          "name": "OGG Audio File",
          "description": "SonicMaster OGG Audio File",
          "icon": "public/icon.png"
        },
        {
          "ext": "m4a",
          "name": "M4A Audio File",
          "description": "SonicMaster M4A Audio File",
          "icon": "public/icon.png"
        },
        {
          "ext": "aac",
          "name": "AAC Audio File",
          "description": "SonicMaster AAC Audio File",
          "icon": "public/icon.png"
        },
        {
          "ext": "wma",
          "name": "WMA Audio File",
          "description": "SonicMaster WMA Audio File",
          "icon": "public/icon.png"
        },
        {
          "ext": "lrc",
          "name": "Lyrics File",
          "description": "SonicMaster Lyrics File",
          "icon": "public/icon.png"
        },
        {
          "ext": "txt",
          "name": "Text File",
          "description": "SonicMaster Text File",
          "icon": "public/icon.png"
        }
      ]
    },
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "prasanth-t0205",
      "repo": "sonicmaster",
      "releaseType": "release"
    }
  },
  "type": "module",
  "private": true,
  "repository": "github:prasanth-t0205/sonicmaster",
  "scripts": {
    "vite-dev": "vite --host 127.0.0.1",
    "vite-build": "vite build",
    "dev": "concurrently \"npm run vite-dev\" \"tsc -p electron -w\" \"wait-on -t 10000 http://127.0.0.1:5173 && wait-on -t 10000 dist-electron/main.js && electron .\"",
    "build": "node build/build.mjs",
    "publish": "node build/build.mjs --publish always",
    "publish:linux": "npm run vite-build && tsc -p electron && electron-builder --linux --publish always",
    "build:inno": "node build/inno.mjs",
    "lint": "eslint",
    "postinstall": "electron-builder install-app-deps",
    "prepare": "husky"
  },
  "main": "dist-electron/main.js",
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "electron-is-dev": "^3.0.1",
    "electron-updater": "^6.8.9",
    "hls.js": "^1.6.16",
    "lucide-react": "^1.18.0",
    "mime-types": "^3.0.2",
    "motion": "^12.40.0",
    "music-metadata": "^11.13.0",
    "node-id3": "^0.2.9",
    "peerjs": "^1.5.5",
    "react-router-dom": "^7.17.0",
    "rough-notation": "^0.5.1",
    "shadcn": "^4.11.0",
    "socket.io-client": "^4.8.3",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0",
    "v8-compile-cache": "^2.4.0"
  },
  "devDependencies": {
    "@base-ui/react": "^1.5.0",
    "@electron/get": "^5.0.0",
    "@hugeicons/core-free-icons": "^4.2.0",
    "@hugeicons/react": "^1.1.6",
    "@tailwindcss/vite": "^4.3.1",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "app-builder-bin": "^4.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "javascript-obfuscator": "^5.4.3",
    "lint-staged": "^17.0.7",
    "next-themes": "^0.4.6",
    "prettier": "^3.8.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "^0.35.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^6",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  },
  "engines": {
    "node": ">=24"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
